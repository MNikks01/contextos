{
  "name": "@mnikks01/contextos",
  "version": "0.1.0",
  "type": "module",
  "description": "ContextOS (#1) engine — durable team context + the Context Handoff: capture decisions/conventions/glossary, export a portable bundle (+ generated CLAUDE.md / AGENTS.md / llms.txt), restore into any AI tool, diff, and extract context from text. Node native TypeScript; zero-network.",
  "bin": {
    "contextos": "src/cli.ts"
  },
  "scripts": {
    "cli": "node src/cli.ts",
    "demo": "node scripts/demo.ts",
    "demo:grounded": "node scripts/demo-grounded.ts",
    "test": "node --test test/*.test.ts",
    "vendor:check": "node scripts/vendor-codebase-engine.mjs --check"
  },
  "engines": {
    "node": ">=23.6"
  },
  "license": "Apache-2.0",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MNikks01/contextos.git",
    "directory": "engine"
  },
  "homepage": "https://github.com/MNikks01/contextos#readme",
  "bugs": "https://github.com/MNikks01/contextos/issues",
  "publishConfig": {
    "access": "public"
  }
}
